# Core
ENV=development
LOG_LEVEL=INFO
COMPOSE_PROJECT_NAME=eventflow

# API
API_HOST=0.0.0.0
API_PORT=8060
# Production: use a long random secret (e.g. openssl rand -hex 32). Never deploy with the default.
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=event_system
POSTGRES_USER=event_user
POSTGRES_PASSWORD=event_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_SECONDS=300
# 0 = отключить лимит (например нагрузочный тест Locust). Иначе при многих запросах с одного IP — 429.
RATE_LIMIT_PER_MINUTE=100

# RabbitMQ — должны совпадать с RABBITMQ_DEFAULT_* в docker-compose (сервис rabbitmq).
# Не используйте встроенного guest для подключения из других контейнеров без сброса тома брокера.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=eventflow
RABBITMQ_PASSWORD=eventflow_dev
# Optional: override queue/topic/group per worker process (see docker-compose worker-* services)
# RABBITMQ_CONSUMER_QUEUE=
# KAFKA_CONSUMER_TOPIC=
# KAFKA_CONSUMER_GROUP=

# Kafka + Schema Registry
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# NATS
NATS_URL=nats://nats:4222
NATS_USE_JETSTREAM=false

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_IDS=123456789,987654321

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
